                    <run bold='true' fontcolor='#cf0b09' fontsize='11'> 0–3 days</run>
                    <run>Æ&#10;&#10;</run>
                    <run bold='true' fontcolor='#000000' fontsize='10'>• Estimated Delay Cost: </run>
                    <run bold='true' fontcolor='#cf0b09' fontsize='11'>₹2.88 lakh</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
